/*INTERPRETACIÓN DE IMAGENES*///se usan el modelo CRAT Y RF PAR ENTRENAMIENTO supervisado
//Sección 1. Clasificación Supervisada: SE USA PARA Proyectos formales de cobertura de suelo
//1.agregar punto
var point = ee.Geometry.Point([9.453, 45.424]) // milán
// 2. filtar Landsat 8 
var landsat = dataset
            .filterBounds(point)
            .filterDate('2019-01-01', '2020-01-01')
            .filter(ee.Filter.lt('CLOUD_COVER',10))
            .sort('CLOUD_COVER')
            .first();
//3. centar imagen
Map.centerObject(landsat ,8);
//4. parametros de mapa a mostrar
var parameVisual = {
    min:7000,
    max: 12000,
    bands: ['SR_B4', 'SR_B3', 'SR_B2']
};
Map.addLayer(landsat, parameVisual,'Imagen landsat 8');
//5 Ahora usaremos la herramienta de geomtetría
/*Esta clasificación es manual y hay que tener una tabla
TABLA
CLASS  CLASS CODE
Forest   0
Developed 1
Water     2
Herbaceous 3*/

//6. Combinar colecciones de funciones de entrenamiento.
var trainingFeatures = ee.FeatureCollection([ 
    forest, developed, water, herbaceous]).flatten();
/*ee.FeatureCollection([...]) → crea una colección de entidades a partir de una lista.

.flatten() → toma una lista de colecciones y las convierte en una sola colección continua, eliminando la jerarquía interna.
*/


//7.Define bandas de predicción
var bandsPrediccion = [
  'SR_B1', 'SR_B2', 'SR_B3', 'SR_B4', 'SR_B5', 'SR_B6', 'SR_B7', 'ST_B10' 
  ];
//8.// Puntos de entrenamiento de ejemplo.
var classifierTraining = landsat.select( bandsPrediccion) 
                        .sampleRegions({collection: trainingFeatures, 
                                       properties: ['class'], 
                                        scale: 30 }
                                        );
print(classifierTraining) // revisar propiedades de las bandas en features
//9.Entrenar un clasificador CART.

var classifier = ee.Classifier.smileCart().train({ 
    features: classifierTraining, 
    classProperty: 'class', 
    inputProperties: bandsPrediccion
}); 

//10. Clasificar la imagen de Landsat.

var classified = landsat.select( bandsPrediccion).classify(classifier); 

//11. Definir parámetros de visualización de imágenes de clasificación.
var classificationVis = { 
        min: 0, 
        max: 3, 
       palette: [
    '228B22', // Forest (verde bosque)
    'FF0000', // Developed (rojo intenso)
    '1E90FF', // Water (azul brillante)
    'FFD700' // Herbaceous (amarillo dorado)
    ] 
    }; 
// Agregar mapa. 
Map.addLayer(classified, classificationVis, 'CART classified'); 
////////////// //////////////////////// //////////////////////
/*intentaremos con otro clasificador de aprendizaje supervisado 
que es ampliamente utilizado: Bosques Aleatorios (RF).*/

//1. Entrenar clasificador RF.

var RFclassifier = ee.Classifier.smileRandomForest(50).train({ 
    features: classifierTraining, 
    classProperty: 'class', 
    inputProperties: bandsPrediccion
});
// 2. Clasificar imagen Landsat.
var RFclassified = landsat.select(bandsPrediccion).classify( 
RFclassifier);
Map.addLayer(RFclassified, classificationVis, 'RF classified');

/*NOTA: En aplicaciones como clasificación de cobertura de suelo en Google Earth Engine, RF suele 
ser preferido porque maneja mejor la
variabilidad de los datos satelitales y ofrece 
resultados más confiables.*/



///////////////Clasificación no supervisada/////////////
/*lOS CLUSTER SE USAN PARA Exploración inicial, cuando no hay datos de campo*/
//1.Crear el conjunto de datos de entrenamiento
var training = landsat.sample({ // sample:toma muestras al azar de una región
      region: landsat.geometry(), 
      scale: 30, 
     numPixels: 1000, 
    tileScale: 8 
    });
//2.Instancia el agrupador (clusterer ) y entrénalo.
/*solicitar cuatro clústeres, el mismo número que para la clasificación 
supervisada, con el fin de compararlos directamente*/
 //Usaremos el algoritmo de agrupamiento k-means
var clusterer = ee.Clusterer.wekaKMeans(4).train(training);
//3.Agrupa la entrada usando el agrupador entrenado: Cluster the input using the trained clusterer.
var Kclassified = landsat.cluster(clusterer); 
//4.Muestra los grupos con colores aleatorios.
Map.addLayer(Kclassified.randomVisualizer(), {}, 
    'K-means classified - random colors');
