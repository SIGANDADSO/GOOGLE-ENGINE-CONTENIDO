/**** Start of imports. If edited, may not auto-convert in the playground. ****/
var sentinel = ee.ImageCollection("COPERNICUS/S2_HARMONIZED");
/***** End of imports. If edited, may not auto-convert in the playground. *****/
// repaso de conceptos de operaciones con imagenes paso básico
// calcular el NDVI manual
// zona de estudio
var pointZone = ee.Geometry.Point([-75.9288, 9.4119]);
// hacemos el filtro de imagenes
var sentinelFiltro = sentinel
                     .filterBounds(pointZone)
                     .filter(ee.Filter.date('2024-01-1', '2025-01-31'))
                     .filterMetadata('CLOUDY_PIXEL_PERCENTAGE', 'less_than', 3) // filtar 3% de nubes
                     .first();
// Agregar al mapa
Map.addLayer(sentinelFiltro,{
       min:0,
       max:3000,
       bands: ['B8', 'B4', 'B3']
        }, 
        'Falso color');
// variables para el ndvi
var nir = sentinelFiltro.select('B8');
var red = sentinelFiltro.select('B4');
// variables del  numerador y denominador
var num = nir.subtract(red );
var denom = nir.add(red);
// calculo del ndvi
var ndvi = num.divide(denom);
// colores para el ndvi
var colores = ['blue', 'white', 'green'];
//agregar al mapa
Map.addLayer(ndvi,{
  min:-1,
  max:1,
    palette: colores
}, 'NDVI');

// LISTO TERMINAMOS AHORA HAGAMOS UN  ULTIMO EJEMPLO PRÁCTICO MAS COMPLEJO

// CALCULAR Índice de Vegetación Mejorado (EVI)
// L=1, C1 = 6, C2 = 7.5, y G (gain factor) = 2.5.
// Sentinel 2 EVI = G*((B8A-B04)/((B8A+C1*B04-C2*B02)+L)). 
var l= 1;
var c1 = 6;
var c2 = 7.5;
var g = 2.5;
//Si el índice tiene una constante (L, C1, C2, G) → SIEMPRE escala la imagen
//Índices solo con suma/resta/división → no necesitan escala
//Índices con constantes → sí necesitan escala como 10000
sentinelFiltro = sentinelFiltro.divide(10000);
var numerador = sentinelFiltro.select('B8A')
                .subtract(sentinelFiltro.select('B4'));
var denomiador = sentinelFiltro.select('B8A')
                .add(sentinelFiltro.select('B4').multiply(c1))
                .subtract(sentinelFiltro.select('B2').multiply(c2))
                .add(l);
var evi =  numerador.multiply(g).divide(denomiador);
colores = ['white', 'yellow', 'green', 'darkgreen'];

Map.addLayer( evi,{
  min:0,
  max:0.8, 
  palette: colores
}, 'EVI');

Map.addLayer(pointZone ,{}, 'Zona de estudio'); // mostrar punto
Map.centerObject(pointZone,14);
// ver cantidad de bandas con la imagen satélital
var images = sentinelFiltro.bandNames();
print('Número de imagenes', images.size());
// escala por resolución espacial del NIR 
var resolusionEspacial = sentinelFiltro.select('B8')
                         .projection().nominalScale();
print('El pixel cubre  en metros: ', resolusionEspacial, 
'que es un área = 10 × 10 = 100 m²')










